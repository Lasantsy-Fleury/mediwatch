  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": [], "displayMode": "list" } },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"mediwatch-backend\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}",
          "refId": "A"
        }
      ],
      "title": "Requêtes HTTP par seconde",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"mediwatch-backend\"}[5m]))",
          "legendFormat": "p95 latence",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"mediwatch-backend\"}[5m]))",
          "legendFormat": "p50 latence",
          "refId": "B"
        }
      ],
      "title": "Latence HTTP (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "mediwatch_active_patients",
          "legendFormat": "Patients actifs",
          "refId": "A"
        }
      ],
      "title": "Patients actifs",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "mediwatch_model_loaded",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ],
      "title": "Modèles ML chargés",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(mediwatch_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 — {{modality}}",
          "refId": "A"
        }
      ],
      "title": "Latence d'inférence ML par modalité",
      "type": "timeseries"
    }
